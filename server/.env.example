# 端口（可选，默认 3001）
# PORT=3001

# 默认模型（可选）
# DEFAULT_MODEL_ID=openai:gpt-4o-mini

# OpenAI API Key（也可在前端「设置」中配置）
OPENAI_API_KEY=

# OpenAI Base URL（可选）
# OPENAI_BASE_URL=

# MCP 服务配置（可选）：必须为合法 JSON 字符串
# stdio 示例：MCP_SERVERS={"math":{"transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-math"]}}
# SSE 示例：MCP_SERVERS={"remote":{"transport":"sse","url":"http://localhost:8000/mcp"}}
